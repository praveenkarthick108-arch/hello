# Required
OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — weather uses mock data if not provided
OPENWEATHERMAP_API_KEY=

# Storage paths (defaults are fine for local dev)
CHROMA_PERSIST_DIR=./chroma_db
SQLITE_URL=sqlite+aiosqlite:///./trip_history.db
PDF_OUTPUT_DIR=./outputs

# Model settings
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
EMBEDDING_MODEL=text-embedding-3-small

# Orchestrator retry limit per agent
MAX_RETRIES_PER_AGENT=3

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
